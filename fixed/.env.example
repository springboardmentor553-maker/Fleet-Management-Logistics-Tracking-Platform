# Copy this file to .env and fill in real values. Never commit the real .env file.

# PostgreSQL connection string used by the backend (SQLAlchemy/Alembic)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/fleetflow_db

# Base URL the frontend uses to reach the backend API
VITE_API_URL=http://127.0.0.1:8000

# Note: location/route features use free OpenStreetMap services
# (Nominatim for geocoding, OSRM for routing) — no API key needed.
